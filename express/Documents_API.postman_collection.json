				"body": {
					"mode": "raw",
					"raw": "{\n  \"src\": \"https://cdn-icons-png.flaticon.com/512/337/337946.png\",\n  \"title\": \"Новый документ.pdf\",\n  \"text\": \"Документ доступен для чтения и скачивания. Последнее изменение: сегодня.\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/documents",
					"protocol": "http",
					"host": ["localhost"],
					"port": "3000",
					"path": ["documents"]
